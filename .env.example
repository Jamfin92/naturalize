# URL of the Naturalization API.
# Defaults to http://localhost:5099 if unset (see src/lib/api.ts).
VITE_API_URL=http://localhost:5099

# --- Okta (not wired on the front end yet) ---
# The BACKEND Okta path is config-only (see the README and the API's appsettings.json).
# The front end still needs an OIDC redirect flow, which this repo does not build.
# These are placeholders for whoever adds it — src/lib/token.ts is the seam a
# redirect flow would deposit its token into.
# VITE_OKTA_ISSUER=https://your-org.okta.com/oauth2/default
# VITE_OKTA_CLIENT_ID=
