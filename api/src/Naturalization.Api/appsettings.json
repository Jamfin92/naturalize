{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Auth": {
    "Jwt": {
      "Issuer": "naturalize",
      "Audience": "naturalize",

      // Empty on purpose. A signing key is a secret, and secrets do not live in
      // source control, so supply one per deployment:
      //
      //     export Auth__Jwt__Key="$(openssl rand -base64 48)"
      //
      // Startup validates it (>= 32 bytes) and refuses to boot without it. A
      // throwaway key for local work lives in appsettings.Development.json.
      "Key": "",

      // Eight hours: one shift. There are no refresh tokens.
      "LifetimeMinutes": 480
    },

    // The Okta carve-out. Completely inert while Enabled is false — no handler is
    // even registered. To move to Okta, fill in these three values:
    //
    //   "Enabled":   true
    //   "Authority": "https://<your-org>.okta.com/oauth2/default"
    //   "Audience":  "api://naturalize"
    //
    // The API then accepts Okta-issued tokens ALONGSIDE locally-issued ones,
    // routing on the token's `iss` claim — so local sign-in keeps working while
    // you migrate, and no code changes. The front end still needs an OIDC redirect
    // flow, which is NOT built. See the README.
    "Okta": {
      "Enabled": false,
      "Authority": "",
      "Audience": ""
    }
  },

  "Seed": {
    // The 40 fabricated applicants. Switched off in the integration tests, which
    // build their own fixtures and want an empty database.
    "Demo": true
  }
}
