{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "Auth": {
    "Jwt": {
      // A throwaway signing key so `dotnet run` works on a fresh clone with no
      // setup. It is public, it is in git, and every fork shares it — which is
      // exactly why it must never reach a deployment. Production reads
      // Auth__Jwt__Key from the environment; startup refuses to boot without one.
      "Key": "naturalize-development-signing-key-not-for-production-use"
    }
  }
}
